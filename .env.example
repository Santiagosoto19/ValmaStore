# Base de datos (Neon PostgreSQL — recomendado en producción)
DATABASE_URL=postgresql://usuario:password@ep-xxxx.us-east-2.aws.neon.tech/valma_db?sslmode=require

# Alternativa local (solo si no usas DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=valma_db
# DB_USER=postgres
# DB_PASSWORD=tu_password

# Servidor
PORT=3000
NODE_ENV=development

# URL pública de la app (obligatorio en Vercel para URLs de imágenes)
BASE_URL=http://localhost:3000

# Autenticación JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=24h

# WhatsApp de la tienda (código país + número, sin espacios)
WHATSAPP_NUMBER=573001234567

# Cloudinary (recomendado en Vercel para subir imágenes desde el admin)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
# CLOUDINARY_FOLDER=valma/products
